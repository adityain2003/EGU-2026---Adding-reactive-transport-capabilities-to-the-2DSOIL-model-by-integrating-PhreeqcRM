SELECTED_OUTPUT
     -active     true
     -reset     false
     -pH     true
     -pe     true
     -charge_balance     true
     -percent_error     true
     -water     true
#     -totals	O [ORGANIC_N] [AMMONIUM] [NITRATE] [NITROUS_GAS]
#     -molalities H2O [ORGANIC_N] [AMMONIUM] [NITRATE] [NITROUS_GAS]
     -kinetic_reactants NITRIFICATION_LAYER_1 NITRIFICATION_LAYER_2 NITRIFICATION_LAYER_3 NITRIFICATION_LAYER_4 NITRIFICATION_LAYER_5 NITRIFICATION_LAYER_6 NITRIFICATION_LAYER_7 NITRIFICATION_LAYER_8

USER_PUNCH 1
-Heading   "TOTMOLE[ORGANIC_N]"
-Heading   "SOLN_VOL"
-Heading   "[ORGANIC_N]/SOLN_VOL"
-Heading   "MOL[ORGANIC_N]"
-Heading   "MOL[AMMONIUM]"
-Heading   "THETA_VMC"
-Heading   "W_FACTOR"
10                      PUNCH TOTMOLE("[ORGANIC_N]") 
20			PUNCH SOLN_VOL
30			PUNCH TOTMOLE("[ORGANIC_N]")/SOLN_VOL
40			PUNCH MOL("[ORGANIC_N]")
50			PUNCH MOL("[AMMONIUM]")
60			PUNCH TOT("[THETA_VMC]")
70			PUNCH (1/(1+6.63*EXP(-5.69*((TOT("[THETA_VMC]")-0.046)/(0.3355-0.046)))))

